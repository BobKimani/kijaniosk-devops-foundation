[Unit]
Description={{ service_description }}
After=network.target

[Service]
User={{ service_user }}
Group={{ service_group }}
WorkingDirectory={{ app_base_dir }}
EnvironmentFile={{ app_config_dir }}/{{ env_file_name }}
ExecStart={{ service_exec_start }}
Restart=always
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target